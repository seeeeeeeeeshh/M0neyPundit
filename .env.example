# AI Assistant API (for multi-agent responses)
AGNES_API_KEY=your_agnes_api_key_here

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Telegram (for Python sync service - optional)
# Sign up at https://my.telegram.org to get API credentials
TELEGRAM_PHONE=+65XXXXXXXX
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_API_ID=your_api_id_here

# Telegram Channels to sync (comma-separated)
TELEGRAM_CHANNELS=@goodlobang,@ThisCounted

# Telegram Sync Settings
SYNC_MESSAGE_LIMIT=100
SYNC_INTERVAL_SECONDS=3600